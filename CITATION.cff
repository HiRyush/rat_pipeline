    given-names: Sanghyeon
    orcid: "https://orcid.org/0009-0006-8789-575X"
    affiliation: "Kyung Hee University"
version: 0.1.0
date-released: "2026-06-09"
license: MIT
repository-code: "https://github.com/HiRyush/rat_pipeline"
url: "https://github.com/HiRyush/rat_pipeline"
keywords:
