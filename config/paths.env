# config/paths.env — 데이터가 실제로 사는 로컬 하드코딩 경로 한곳 정리.
#
# 주의: 각 스크립트는 아직 내부에 절대경로를 직접 박아두고 있다(이 파일을 source하지 않음).
#       이 파일은 "어떤 step이 무엇을 읽고 쓰는지" 한눈에 보기 위한 참조 문서다.
#       향후 스크립트를 이 변수들로 치환하면 단일 진실 공급원이 된다.

export RAT_ROOT="/home/yusanghyeon/RAT_project"
export CONDA="$RAT_ROOT/miniforge3"          # source $CONDA/etc/profile.d/conda.sh; conda activate rnaseq

# ---- PHMG_IT (Rat rn7, 개발 + Validation 1) ----
export PHMG_IT="$RAT_ROOT/PHMG_IT"
export PHMG_IT_REF="$PHMG_IT/reference/rn7.fa"          # + star_index/
export PHMG_IT_BAM="$PHMG_IT/results/mutect2"           # markdup BAM + force-call VCF
export PHMG_IT_IMPUTE="$PHMG_IT/imputation"             # imputed/ rna_gl/ ref_panel(HRDP 75-strain)/
export PHMG_IT_TRUTH="$PHMG_IT/results/ground_truth"    # DNA WGS SNP VCF (15 samples)
export PHMG_IT_COWORKER="$PHMG_IT/coworker"             # run_pipeline.py (Fisher differential)

# ---- mammary_cancer (Rat rn6, Validation 2) ----
export MAMMARY="$RAT_ROOT/mammary_cancer"
export MAMMARY_REF="$MAMMARY/reference/rn6/Rnor_6.0.fa" # + star_rn6/
export MAMMARY_IMPUTE="$MAMMARY/imputation"             # HRDP 48-strain, GL-based
export MAMMARY_TRUTH="$MAMMARY/ground_truth"            # WES VCF
export MAMMARY_FORCE="$MAMMARY/results/mutect2/force_call"

# ---- pipeline_candidates (관측-우선 최종 산출 작업공간) ----
export CAND="$RAT_ROOT/pipeline_candidates"
export CAND_FINAL="$CAND/results/observation_first"    # 1,392 candidate set, gene_mapping/, ablation/

# ---- PHMG_IH (RNA-only 최종 적용 대상) ----
export PHMG_IH="$RAT_ROOT/PHMG_IH"                      # fastq/ (~145GB), DNA truth 없음
